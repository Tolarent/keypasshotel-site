# ── Hôtel ────────────────────────────────────────────────────────────────────
HOTEL_NAME=Hôtel Le Grand Palais
HOTEL_PHONE=+33 1 XX XX XX XX

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3001
DASHBOARD_URL=http://localhost:3000

# ── Contrôleur de serrures ────────────────────────────────────────────────────
# Rempli automatiquement par le setup wizard
LOCK_BRAND=assa_abloy
LOCK_IP=192.168.1.100
LOCK_PORT=8080
LOCK_API_USER=admin
LOCK_API_PASSWORD=

# ── Apple Wallet ──────────────────────────────────────────────────────────────
# À obtenir depuis developer.apple.com
APPLE_PASS_TYPE_ID=pass.hotel.keypass
APPLE_TEAM_ID=88N329A6GU
# Chemins vers les certificats (générés par le setup)
APPLE_CERT_PATH=./certs/signerCert.pem
APPLE_KEY_PATH=./certs/signerKey.pem
APPLE_WWDR_PATH=./certs/WWDR.pem

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=reservation@monhotel.fr
SMTP_PASSWORD=
SMTP_FROM_NAME=Hôtel Le Grand Palais

# ── Sécurité ──────────────────────────────────────────────────────────────────
